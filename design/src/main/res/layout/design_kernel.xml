<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable name="currentVersion" type="String" />
        <variable name="stableVersion" type="String" />
        <variable name="latestVersion" type="String" />
        <variable name="alphaVersion" type="String" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dialog_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="@dimen/about_icon_size"
                android:layout_height="@dimen/about_icon_size"
                android:background="@drawable/ic_flowly_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/about_text_margin"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/kernel"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/kernel_sub"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                    android:alpha="0.7" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?colorLineSoft" />

        <!-- Current version bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_settings_icon"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kernel_current_label"
                android:textSize="12sp"
                android:alpha="0.5" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/current_version_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{currentVersion ?? @string/kernel_current_value}'
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/kernel_badge_current"
                android:textSize="10sp"
                android:textColor="?colorPrimary"
                android:textStyle="bold"
                android:background="@drawable/bg_settings_icon"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Channel selection hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.05"
            android:text="@string/kernel_select_hint"
            android:textSize="12sp"
            android:alpha="0.5" />

        <!-- Stable Channel -->
        <LinearLayout
            android:id="@+id/channel_stable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_settings_icon"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kernel_channel_stable"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginStart="6dp"
                        android:background="@android:color/transparent" />
                </LinearLayout>

                <TextView
                    android:id="@+id/stable_version_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text='@{stableVersion ?? @string/kernel_fetching}'
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_stable"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/kernel_download"
                android:textSize="12sp"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Latest (Pre-release) Channel -->
        <LinearLayout
            android:id="@+id/channel_latest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_settings_icon"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/kernel_channel_latest"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/latest_version_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text='@{latestVersion ?? @string/kernel_fetching}'
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_latest"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/kernel_download"
                android:textSize="12sp"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Alpha / Pre-release Channel -->
        <LinearLayout
            android:id="@+id/channel_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_settings_icon"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kernel_channel_alpha"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_settings_icon"
                        android:paddingStart="4dp"
                        android:paddingTop="1dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="1dp"
                        android:text="@string/kernel_tag_pre"
                        android:textColor="?attr/colorError"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/alpha_version_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text='@{alphaVersion ?? @string/kernel_fetching}'
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_alpha"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/kernel_download"
                android:textSize="12sp"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Revert to Built-in Kernel (visible only when custom kernel active) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_revert_builtin"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/kernel_revert_builtin"
            android:textSize="12sp"
            app:cornerRadius="16dp"
            android:visibility="gone" />

        <!-- Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/kernel_note_v2"
            android:textSize="12sp"
            android:alpha="0.55" />

        <!-- Releases link button -->
        <Button
            android:id="@+id/releases_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/kernel_releases"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>
</layout>
