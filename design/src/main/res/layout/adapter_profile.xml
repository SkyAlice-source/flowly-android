<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="profile"
            type="com.github.kr328.clash.service.model.Profile" />
        <variable
            name="currentTime"
            type="com.github.kr328.clash.design.ui.ObservableCurrentTime" />
        <variable
            name="clicked"
            type="android.view.View.OnClickListener" />
        <variable
            name="menu"
            type="com.github.kr328.clash.design.adapter.ProfileActions" />
        <import type="android.view.View" />
        <import type="com.github.kr328.clash.design.util.I18nKt" />
        <import type="com.github.kr328.clash.design.util.IntervalKt" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="14dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="14dp"
        android:layout_marginBottom="5dp"
        android:minHeight="84dp"
        android:foreground="?selectableItemBackground"
        android:focusable="true"
        android:clickable="true"
        app:cardCornerRadius="16dp"
        app:cardElevation="0.5dp"
        app:strokeColor="?colorLineSoft"
        app:strokeWidth="0.5dp"
        android:onClick="@{clicked}">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@{profile.name}"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:paddingLeft="9dp"
                    android:paddingTop="4dp"
                    android:paddingRight="9dp"
                    android:paddingBottom="4dp"
                    android:text="@string/active"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="?colorPrimary"
                    android:visibility="@{profile.active ? View.VISIBLE : View.GONE}" />

                <TextView
                    android:id="@+id/action_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:paddingLeft="8dp"
                    android:paddingTop="3dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="3dp"
                    android:text="@string/update"
                    android:textSize="10sp"
                    android:textColor="?colorControlNormal"
                    android:visibility="@{profile.imported &amp;&amp; profile.type != com.github.kr328.clash.service.model.Profile.Type.File ? View.VISIBLE : View.GONE}"
                    android:onClick="@{() -> menu.onUpdate(profile)}" />

                <TextView
                    android:id="@+id/action_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:paddingLeft="8dp"
                    android:paddingTop="3dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="3dp"
                    android:text="@string/edit"
                    android:textSize="10sp"
                    android:textColor="?colorControlNormal"
                    android:onClick="@{() -> menu.onEdit(profile)}" />

                <TextView
                    android:id="@+id/action_duplicate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:paddingLeft="8dp"
                    android:paddingTop="3dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="3dp"
                    android:text="@string/duplicate"
                    android:textSize="10sp"
                    android:textColor="?colorControlNormal"
                    android:visibility="@{profile.imported ? View.VISIBLE : View.GONE}"
                    android:onClick="@{() -> menu.onDuplicate(profile)}" />

                <TextView
                    android:id="@+id/action_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:paddingLeft="8dp"
                    android:paddingTop="3dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="3dp"
                    android:text="@string/delete"
                    android:textSize="10sp"
                    android:textColor="?attr/colorError"
                    android:onClick="@{() -> menu.onDelete(profile)}" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:textSize="12sp"
                    android:textColor="?colorControlNormal"
                    android:text='@{profile.pending ? @string/format_type_unsaved(I18nKt.toString(profile.type, context)) : I18nKt.toString(profile.type, context)}' />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:textSize="12sp"
                    android:textColor="?colorControlNormal"
                    android:text="@{IntervalKt.elapsedIntervalString(currentTime.value - profile.updatedAt, context)}" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="@{profile.download &lt; 2 ? View.GONE : View.VISIBLE}">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="?colorControlNormal"
                    android:text='@{profile.download > 1 ? I18nKt.toBytesString(profile.download + profile.upload) : ""}' />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:alpha="0.4"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:textColor="?colorControlNormal"
                    android:text="/" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="?colorControlNormal"
                    android:text='@{profile.total > 1 ? I18nKt.toBytesString(profile.total) : ""}' />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ProgressBar
                    style="?android:progressBarStyleHorizontal"
                    android:layout_width="80dp"
                    android:layout_height="6dp"
                    android:max="1000"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:progress="@{profile.total > 1 ? I18nKt.toProgress((profile.download + profile.upload) / (profile.total / 1000)) : 0}" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:alpha="0.7"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="?colorPrimary"
                    android:text='@{profile.total > 1 ? I18nKt.toPercentString(profile.download + profile.upload, profile.total) : ""}' />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="@{profile.expire == 0 ? View.GONE : View.VISIBLE}">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/expire"
                    android:textSize="11sp"
                    android:textColor="?colorControlNormal"
                    android:alpha="0.7" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?colorControlNormal"
                    android:text='@{profile.expire > 0 ? I18nKt.toDateStr(profile.expire) : ""}' />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
